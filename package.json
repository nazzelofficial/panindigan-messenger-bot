{
  "name": "nazzel-messenger-userbot",
  "version": "2.12.5",
  "description": "Advanced Facebook Messenger User-Bot with TypeScript, PostgreSQL, and comprehensive logging",
  "main": "dist/main.js",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "start": "node --max-old-space-size=4096 dist/main.js",
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "messenger",
    "userbot",
    "facebook",
    "typescript",
    "chatbot",
    "postgresql"
  ],
  "author": "Nazzel",
  "license": "SEE LICENSE IN LICENSE.md",
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "@tensorflow/tfjs": "^4.22.0",
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "file-type": "^22.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "jimp": "^1.6.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "nsfwjs": "^4.2.1",
    "openai": "^4.83.0",
    "panindigan-fca": "0.1.2",
    "pg": "^8.13.1",
    "unzipper": "^0.12.3",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "yt-search": "^2.13.1",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
